{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",

    /* Bundler mode (Vite builds/bundles; tsc here only type-checks) */
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* App-specific linting on top of the shared base */
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true,

    /*
     * Override: the shared base (tsconfig.base.json) sets
     * noUncheckedIndexedAccess:true, which produces heavy noise across the
     * ported feature/page code (every array/record index access needs a
     * defensive undefined check). All OTHER strict flags stay on for the
     * client (see above) — this is the one specific override called for by
     * the extraction plan (_ai_tasks/opensource-extraction §6 tsconfig item).
     */
    "noUncheckedIndexedAccess": false,

    /* Import path aliases (must match vite.config.ts's `@` alias) */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "components/*": ["./src/components/*"],
      "src/*": ["./src/*"]
    }
  },
  "include": ["src"],
  "exclude": [
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.spec.ts",
    "**/*.test.tsx",
    "**/*.spec.tsx",
    "src/tests/**/*"
  ]
}
