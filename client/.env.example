# Veltrix Community Edition — client (Vite) environment template.
# Copy to .env.local for local `vite dev` overrides. Every var below is
# optional; the app runs with sensible defaults if none are set.

# ---- API ----
# Base URL the client calls for every /api/* request.
VITE_API_URL=http://localhost:5000/api

# ---- Branding (build-time bake-in) ----
# These are the BUILD-TIME override path. The primary, no-rebuild-required
# rebrand path is the server-served `GET /api/brand` (see the root
# .env.example's VELTRIX_BRAND_* vars) — src/brand.ts prefers that response
# over these when both are present. Leave unset to ship as "Veltrix".
# VITE_BRAND_NAME=Veltrix
# VITE_BRAND_TAGLINE=Security-as-Code
# VITE_BRAND_VENDOR=
# VITE_BRAND_LOGO_URL=/assets/logo.svg
# VITE_APP_VERSION=0.1.0
# VITE_BRAND_SUPPORT_URL=https://github.com/captivatortechnologies/veltrix-community

# ---- OpenTelemetry web tracing (OFF by default) ----
# See src/lib/telemetry.ts — initTelemetry() no-ops unless this is "true".
# VITE_OTEL_ENABLE_TRACING=false
# VITE_OTEL_SERVICE_NAME=veltrix-client
# VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# VITE_OTEL_SAMPLE_RATE=1.0
