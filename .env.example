# =============================================================================
# Veltrix Community Edition — environment template
# Copy to .env and fill in. NEVER commit a real .env (it is gitignored).
# The server FAILS FAST at startup if the required secrets below are unset.
# Generate strong values, e.g.:  openssl rand -hex 32
# =============================================================================

# ---- Core ----
NODE_ENV=development
PORT=5000
# Public URL of the client (for CORS / links). Defaults to the web UI's
# published host port (8730). Set this to your real domain in production.
APP_URL=http://localhost:8730

# ---- Database (PostgreSQL 16) ----
DATABASE_URL=postgresql://veltrix:CHANGE_ME@localhost:5432/veltrix

# ---- Cache / Job queue (Redis 7 — powers BullMQ pipeline jobs) ----
REDIS_URL=redis://localhost:6379

# ---- Secrets (REQUIRED — no defaults; startup aborts if missing) ----
JWT_SECRET=CHANGE_ME_generate_a_32_byte_hex
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_different_32_byte_hex
# AES-256 key for credential encryption at rest (32 bytes hex)
ENCRYPTION_KEY=CHANGE_ME_generate_a_32_byte_hex
COOKIE_SECRET=CHANGE_ME_generate_a_32_byte_hex

# ---- First-run admin (created on first boot; change password on first login) ----
VELTRIX_ADMIN_EMAIL=admin@example.com
# If unset, a random password is generated and printed ONCE to the server log.
VELTRIX_ADMIN_PASSWORD=

# ---- Branding (Community Edition brand is fully configurable) ----
VELTRIX_BRAND_NAME=Veltrix
VELTRIX_BRAND_TAGLINE=Security-as-Code
VELTRIX_BRAND_LOGO_URL=

# ---- Apps ----
# Directory the app engine discovers apps from (checkout of the apps repo).
APPS_DIR=./apps

# ---- Email / SMTP (password-reset delivery) ----
# Outbound email is OPTIONAL. With no provider configured, password-reset links
# are written to the server log so you can still recover accounts. You can also
# configure this in the UI (Settings -> Email), which overrides these vars.
# EMAIL_PROVIDER: "smtp" | "ses" | "none"
EMAIL_PROVIDER=none
EMAIL_FROM=Veltrix <no-reply@example.com>
# --- SMTP transport (works with SendGrid, Mailgun, Postmark, Gmail, etc.) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false        # true for implicit TLS on port 465; false for STARTTLS on 587
SMTP_USER=
SMTP_PASS=
# --- Amazon SES transport (leave keys blank to use the default AWS credential chain) ---
SES_REGION=
SES_ACCESS_KEY_ID=
SES_SECRET_ACCESS_KEY=
# How long a password-reset link stays valid.
PASSWORD_RESET_TTL_MINUTES=60

# ---- Optional SSO (all OFF by default; local auth is the default) ----
FEATURE_OAUTH_COGNITO=false
FEATURE_OAUTH_GOOGLE=false
FEATURE_OAUTH_MICROSOFT=false
FEATURE_OAUTH_OIDC=false
# Provide these only when the matching provider is enabled:
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_TENANT_ID=
# OIDC_ISSUER_URL=

# ---- Pipeline features (FREE in Community Edition — enabled by default) ----
FEATURE_PIPELINE_DRIFT_DETECTION=true
FEATURE_PIPELINE_CANARY=true
FEATURE_PIPELINE_BLUE_GREEN=true
FEATURE_PIPELINE_APPROVALS=true

# ---- Platform features ----
FEATURE_WEBHOOKS=true
# Hosted/managed connectivity + cloud provisioning are commercial — leave false
FEATURE_HOSTED_CONNECTIVITY=false
FEATURE_CLOUD_PROVISIONING=false

# ---- Commercial features (NOT included in Community Edition — leave false) ----
FEATURE_BILLING=false
FEATURE_MULTI_TENANT=false
