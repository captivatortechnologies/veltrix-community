# Normalize line endings. Text files are stored with LF in the repo; this keeps
# diffs clean and — critically — keeps shell scripts LF even when checked out on
# Windows, so they don't break on Linux / in CI / inside containers.
* text=auto eol=lf

# Scripts and Unix-y files MUST be LF.
*.sh   text eol=lf
*.bash text eol=lf
Dockerfile      text eol=lf
*.Dockerfile    text eol=lf

# Windows-only scripts use CRLF.
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Binary assets — never normalize.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.pdf  binary
