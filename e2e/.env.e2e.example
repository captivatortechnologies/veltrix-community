# Veltrix Community Edition — E2E test environment (EXAMPLE)
#
# Copy this file to `.env.e2e` (gitignored) and fill in values that match your local
# dev seed. playwright.config.ts loads `.env.e2e` automatically. You can also export
# these variables directly instead of using a file.
#
# NEVER commit real credentials. Every value below is a placeholder.

# --- Running dev stack ------------------------------------------------------
# The Vite client and Fastify API the suite drives.
E2E_BASE_URL=http://localhost:5173
E2E_API_URL=http://localhost:5000/api

# --- Dev fixture user (server/prisma/seed/dev-user.ts) ----------------------
# Set E2E_PASSWORD to the password your local seed created for this account.
E2E_EMAIL=dev@local.test
E2E_PASSWORD=

# --- Seeded admin account (server/prisma/seed/admin-account.ts) -------------
# Used by helpers.adminToken(). Set E2E_ADMIN_PASSWORD to match your seed.
E2E_ADMIN_EMAIL=admin@veltrix.local
E2E_ADMIN_PASSWORD=

# --- Fixture users this suite creates at runtime ----------------------------
# Optional. If unset, a per-run random value that meets the server's password
# complexity policy is generated automatically. Only set it if you need a fixed
# value; if you do, it must satisfy the complexity policy.
E2E_TEST_PASSWORD=

# --- App under test ---------------------------------------------------------
# App slug used by the app-scoped specs (installed by default in dev).
E2E_APP_ID=crowdstrike-edr
