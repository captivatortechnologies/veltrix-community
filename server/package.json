{
  "name": "@veltrix/server",
  "version": "0.1.0",
  "description": "Veltrix Community Edition — Security-as-Code platform backend (Fastify + Prisma). Optional SSO plugins (@aws-sdk/client-cognito-identity-provider, aws-jwt-verify, google-auth-library, @azure/msal-node) are only exercised when their feature flag is enabled (config/feature-flags.ts oauth.*) — local email+password auth is the self-host default. aws-sdk (v2) is pulled in by the module/cloud-account BYOC adapter, gated off by default (platform.cloudProvisioning) — kept as a normal dependency purely so that module still type-checks/builds.",
  "private": true,
  "license": "Apache-2.0",
  "main": "dist/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "test:ci": "jest --ci --coverage --maxWorkers=2",
    "lint": "tsc --noEmit -p tsconfig.json",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "db:seed": "ts-node prisma/seed/index.ts"
  },
  "dependencies": {
    "@aws-sdk/client-cognito-identity-provider": "^3.760.0",
    "@azure/msal-node": "^3.8.3",
    "@fastify/compress": "^8.3.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.4.2",
    "@fastify/swagger-ui": "^5.2.2",
    "@prisma/client": "^6.4.1",
    "@sinclair/typebox": "^0.34.33",
    "adm-zip": "^0.5.16",
    "aws-jwt-verify": "^5.2.1",
    "aws-sdk": "^2.1692.0",
    "axios": "^1.8.1",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.70.4",
    "dotenv": "^16.4.7",
    "envalid": "^8.1.1",
    "esbuild": "^0.28.1",
    "fastify": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "ioredis": "^5.8.2",
    "jose": "^4.15.9",
    "js-yaml": "^4.1.0",
    "jsonwebtoken": "^9.0.2",
    "otplib": "^12.0.1",
    "pg": "^8.14.0",
    "sharp": "^0.33.5",
    "socket.io": "^4.8.1",
    "tar": "^7.5.10",
    "uuid": "^9.0.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.7",
    "@types/bcrypt": "^5.0.2",
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^22.10.6",
    "@types/uuid": "^9.0.8",
    "jest": "^29.7.0",
    "prisma": "^6.4.1",
    "socket.io-client": "^4.8.3",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
